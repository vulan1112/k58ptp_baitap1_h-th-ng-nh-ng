0078:  MOVWF  73
0079:  CALL   012
....................   RTC_I2C_WRITE(pin_out); 
007A:  MOVF   6E,W
007B:  MOVWF  73
007C:  CALL   012
....................   RTC_I2C_STOP(); 
007D:  BSF    03.5
007E:  BSF    11.2
007F:  BTFSC  11.2
0080:  GOTO   07F
0081:  BCF    03.5
0082:  BSF    0A.3
0083:  BCF    0A.4
0084:  GOTO   293 (RETURN)
.................... } 
....................  
.................... // enables RTC oscillator 
.................... void OSC_Enable() 
*
0051:  CLRF   71
0052:  CALL   032
0053:  MOVF   78,W
0054:  MOVWF  6E
.................... { 
....................   uint8_t sec_reg = RTC_Read_Reg(DS1307_REG_SECONDS); 
....................   sec_reg &= 0x7F; 
0055:  BCF    6E.7
....................   RTC_Write_Reg(DS1307_REG_SECONDS, sec_reg); 
0056:  CLRF   6F
0057:  MOVF   6E,W
0058:  MOVWF  70
*
006B:  BCF    03.5
006C:  BSF    0A.3
006D:  BCF    0A.4
006E:  GOTO   28E (RETURN)
.................... } 
....................  
.................... // disables RTC oscillator 
.................... void OSC_Disable() 
.................... { 
....................   uint8_t sec_reg = RTC_Read_Reg(DS1307_REG_SECONDS); 
....................   sec_reg |= 0x80; 
....................   RTC_Write_Reg(DS1307_REG_SECONDS, sec_reg); 
.................... } 
