....................  
.................... // converts BCD to decimal 
.................... uint8_t bcd_to_decimal(uint8_t number) 
.................... { 
....................   return ( (number >> 4) * 10 + (number & 0x0F) ); 
*
00AA:  SWAPF  6E,W
00AB:  MOVWF  77
00AC:  MOVLW  0F
00AD:  ANDWF  77,F
00AE:  MOVF   77,W
00AF:  MOVWF  70
00B0:  MOVWF  74
00B1:  MOVLW  0A
00B2:  MOVWF  75
00B3:  CALL   085
00B4:  MOVF   78,W
00B5:  MOVWF  6F
00B6:  MOVF   6E,W
00B7:  ANDLW  0F
00B8:  ADDWF  78,W
00B9:  MOVWF  78
00BA:  RETURN
.................... } 
....................  
.................... // converts decimal to BCD 
.................... uint8_t decimal_to_bcd(uint8_t number) 
.................... { 
....................   return ( ((number / 10) << 4) + (number % 10) ); 
*
0691:  MOVF   74,W
0692:  MOVWF  76
0693:  MOVLW  0A
0694:  MOVWF  7B
0695:  CALL   67C
0696:  SWAPF  78,W
0697:  MOVWF  75
0698:  MOVLW  F0
0699:  ANDWF  75,F
069A:  MOVF   74,W
069B:  MOVWF  76
069C:  MOVLW  0A
069D:  MOVWF  7B
069E:  CALL   67C
069F:  MOVF   77,W
06A0:  ADDWF  75,W
06A1:  MOVWF  78
06A2:  RETURN
.................... } 
