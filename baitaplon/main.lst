....................  
.................... // writes 'reg_value' to register of address 'reg_address' 
.................... void RTC_Write_Reg(uint8_t reg_address, uint8_t reg_value) 
.................... { 
....................   RTC_I2C_START(); 
*
0059:  BSF    03.5
005A:  BSF    11.0
005B:  BTFSC  11.0
005C:  GOTO   05B
....................   RTC_I2C_WRITE(DS1307_ADDRESS); 
005D:  MOVLW  D0
005E:  MOVWF  73
005F:  BCF    03.5
0060:  CALL   012
....................   RTC_I2C_WRITE(reg_address); 
0061:  MOVF   6F,W
0062:  MOVWF  73
0063:  CALL   012
....................   RTC_I2C_WRITE(reg_value); 
0064:  MOVF   70,W
0065:  MOVWF  73
0066:  CALL   012
....................   RTC_I2C_STOP(); 
0067:  BSF    03.5
0068:  BSF    11.2
0069:  BTFSC  11.2
006A:  GOTO   069
.................... } 
....................  
.................... // returns the value stored in register of address 'reg_address' 
.................... uint8_t RTC_Read_Reg(uint8_t reg_address) 
.................... { 
....................   uint8_t reg_data; 
....................  
....................   RTC_I2C_START(); 
*
0032:  BSF    03.5
0033:  BSF    11.0
0034:  BTFSC  11.0
0035:  GOTO   034
....................   RTC_I2C_WRITE(DS1307_ADDRESS); 
0036:  MOVLW  D0
0037:  MOVWF  73
0038:  BCF    03.5
0039:  CALL   012
....................   RTC_I2C_WRITE(reg_address); 
003A:  MOVF   71,W
003B:  MOVWF  73
003C:  CALL   012
....................   RTC_I2C_START(); 
003D:  BSF    03.5
003E:  BSF    11.1
003F:  BTFSC  11.1
0040:  GOTO   03F
....................   RTC_I2C_WRITE(DS1307_ADDRESS | 0x01); 
0041:  MOVLW  D1
0042:  MOVWF  73
0043:  BCF    03.5
0044:  CALL   012
....................   reg_data = RTC_I2C_READ(0); 
0045:  CLRF   77
0046:  CALL   022
0047:  MOVF   78,W
0048:  MOVWF  72
....................   RTC_I2C_STOP(); 
0049:  BSF    03.5
004A:  BSF    11.2
004B:  BTFSC  11.2
004C:  GOTO   04B
....................  
....................   return reg_data; 
004D:  MOVF   72,W
004E:  MOVWF  78
004F:  BCF    03.5
0050:  RETURN
.................... } 
