.................... #define DS1307_ADDRESS      0xD0 
.................... #define DS1307_REG_SECONDS  0x00 
.................... #define DS1307_REG_CONTROL  0x07 
....................  
.................... enum SQWE 
.................... { 
....................   OUT_OFF = 0x00, 
....................   OUT_ON  = 0x80, 
....................   OUT_1Hz = 0x10, 
....................   OUT_4096Hz  = 0x11, 
....................   OUT_8192Hz  = 0x12, 
....................   OUT_32768Hz = 0x13 
.................... }; 
